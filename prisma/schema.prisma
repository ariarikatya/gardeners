datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  GARDENER
}

model User {
  id         String    @id @default(uuid())
  phone      String    @unique
  name       String
  role       Role      @default(GARDENER)
  gardenerId String?   @unique
  gardener   Gardener? @relation(fields: [gardenerId], references: [id], onDelete: Cascade)
}

model Gardener {
  id       String    @id @default(uuid())
  name     String
  phone    String    @unique
  user     User?
  orders   Order[]
  dayOffs  DayOff[]
  services Service[] @relation("GardenerServices")
}

model Service {
  id        String     @id @default(uuid())
  name      String     @unique
  gardeners Gardener[] @relation("GardenerServices")
  orders    Order[]
}

model Order {
  id             String   @id @default(uuid())
  date           DateTime // Только дата (без учета времени, YYYY-MM-DD)
  dayOfWeek      String
  clientName     String
  address        String
  clientPhone    String
  description    String
  priceContract  Float    @default(0) // Оговоренная сумма
  priceFact      Float    @default(0) // Сумма по факту
  employeeSalary Float    @default(0) // З/п сотрудника
  companyShare   Float    @default(0) // Доля фирмы
  status         String   @default("Новый заказ") // "Новый заказ" | "Перенос" | "Отказ" | "Выполнен" | "Отменен"
  comment        String?
  transferRequestedDate DateTime? // Желаемая дата клиента при запросе переноса от садовника
  refusalReason  String?  // Причина отказа, вводит садовник
  gardenerId     String
  gardener       Gardener @relation(fields: [gardenerId], references: [id], onDelete: Cascade)
  serviceId      String?
  service        Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([date, gardenerId]) // Один садовник может иметь несколько заказов в один день
}

model DayOff {
  id         String   @id @default(uuid())
  date       DateTime // Только дата (YYYY-MM-DD)
  gardenerId String
  gardener   Gardener @relation(fields: [gardenerId], references: [id], onDelete: Cascade)

  @@unique([date, gardenerId]) // Выходной либо есть, либо нет — на один день одна отметка
}
