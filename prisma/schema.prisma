datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  GARDENER
}

model User {
  id         String    @id @default(uuid())
  phone      String    @unique
  name       String
  role       Role      @default(GARDENER)
  gardenerId String?   @unique
  gardener   Gardener? @relation(fields: [gardenerId], references: [id], onDelete: Cascade)
}

model Gardener {
  id     String @id @default(uuid())
  name   String
  phone  String @unique
  user   User?
  orders Order[]
}

model Order {
  id             String   @id @default(uuid())
  date           DateTime
  dayOfWeek      String
  clientName     String
  address        String
  clientPhone    String
  description    String
  priceContract  Float    @default(0)
  priceFact      Float    @default(0)
  employeeSalary Float    @default(0)
  companyShare   Float    @default(0)
  status         String   @default("Новый заказ")
  comment        String?
  gardenerId     String
  gardener       Gardener @relation(fields: [gardenerId], references: [id], onDelete: Cascade)

  @@index([date, gardenerId])
}
